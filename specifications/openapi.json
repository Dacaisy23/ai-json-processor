{
  "openapi": "3.0.3",
  "info": {
    "title": "AI JSON Processor API",
    "version": "1.0.0",
    "description": "Serverless microservice turning raw text into clean schemas via Gemini."
  },
  "paths": {
    "/v1/process-text": {
      "post": {
        "summary": "Transforms unstructured text using AI models",
        "operationId": "processText",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string"
                  }
                },
                "required": ["text"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully structured JSON response layout",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}
